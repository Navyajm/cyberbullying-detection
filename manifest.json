{
  "manifest_version": 3,
  "name": "CyberGuard",
  "version": "1.0.0",
  "description": "Hinglish cyberbullying detection for social media using AI",
  
  "permissions": [
    "storage",
    "activeTab",
    "notifications"
  ],
  
  "host_permissions": [
    "http://localhost:5000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://twitter.com/*",
        "https://x.com/*",
        "https://www.instagram.com/*",
        "https://www.facebook.com/*",
        "https://www.reddit.com/*",
        "https://old.reddit.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "CyberGuard"
  }
}
